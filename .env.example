# PRSM Environment Configuration
# Copy this file to .env: cp .env.example .env
# Then edit with your values.
#
# IMPORTANT: Never commit actual API keys or secrets to version control!
# All sensitive values should be placeholder values in this file.

# ========================================
# TABLE OF CONTENTS
# ========================================
# 1. Core Settings (Required)
# 2. AI Backends (Optional - at least one recommended)
# 3. Blockchain / Web3 (Optional)
# 4. Networking (Optional)
# 5. Database (Optional)
# 6. Redis Cache (Optional)
# 7. IPFS Storage (Optional)
# 8. Vector Databases (Optional)
# 9. Security Settings (Optional)
# 10. Monitoring & Logging (Optional)
# 11. NWTN Configuration (Optional)
# 12. FTNS Token Economy (Optional)
# 13. Payment Gateway (Optional)
# 14. Price Oracle Configuration (Optional)
# 15. Agent Configuration (Optional)
# 16. Governance (Optional)
# 17. Secrets Management (Optional)

# ========================================
# 1. CORE SETTINGS (Required)
# ========================================
# Environment mode: development, testing, staging, production
# [REQUIRED] Determines feature availability and security settings
PRSM_ENV=development

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
# [REQUIRED] Controls verbosity of application logs
PRSM_LOG_LEVEL=INFO

# Secret key for JWT signing and session encryption
# [REQUIRED in production] Must be cryptographically random and at least 64 characters
# Development default is intentionally weak — NEVER use in production
#
# Generate a secure key:
#   openssl rand -hex 32    → 64-character hex string (recommended)
#   python -c "import secrets; print(secrets.token_hex(32))"
#
# Minimum: 32 characters (development only)
# Required: 64+ characters in production (PRSM_ENV=production)
PRSM_SECRET_KEY=change-me-to-a-random-string-at-least-32-chars

# Application port
# [OPTIONAL] Default: 8000
PRSM_PORT=8000

# Debug mode
# [OPTIONAL] Default: false - Set to true only in development
PRSM_DEBUG=false

# Application environment (alternative to PRSM_ENV)
# [OPTIONAL] Used by some security modules
APP_ENV=development

# ========================================
# 2. AI BACKENDS (Optional)
# ========================================
# At least one AI backend is recommended for full functionality.
# The system works in basic mode without these.

# --- Anthropic (Claude) ---
# [OPTIONAL] API key for Claude inference
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# --- OpenAI (GPT) ---
# [OPTIONAL] API key for GPT inference and embeddings
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# --- Hugging Face ---
# [OPTIONAL] API key for Hugging Face models
# Get your key at: https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=

# --- Local Model Configuration ---
# [OPTIONAL] Path to local model files for offline inference
PRSM_LOCAL_MODEL_PATH=

# [OPTIONAL] URL for local Ollama/vLLM server
# Default: http://localhost:11434 (Ollama default)
PRSM_LOCAL_MODEL_URL=

# [OPTIONAL] Ollama host address
# Default: http://localhost:11434
PRSM_OLLAMA_HOST=http://localhost:11434

# [OPTIONAL] Enable Ollama backend
# Default: true
PRSM_USE_OLLAMA=true

# [OPTIONAL] Path for local models storage
PRSM_LOCAL_MODELS_PATH=/models

# --- Backend Selection ---
# [OPTIONAL] Primary backend: anthropic, openai, local, mock
# Default: mock (for testing without API keys)
PRSM_PRIMARY_BACKEND=mock

# [OPTIONAL] Fallback chain (comma-separated)
# Default: anthropic,openai,local,mock
PRSM_FALLBACK_CHAIN=anthropic,openai,local,mock

# [OPTIONAL] Backend timeout in seconds
# Default: 120
PRSM_BACKEND_TIMEOUT=120

# [OPTIONAL] Maximum retry attempts
# Default: 3
PRSM_BACKEND_MAX_RETRIES=3

# [OPTIONAL] Retry delay in seconds
# Default: 1.0
PRSM_BACKEND_RETRY_DELAY=1.0

# [OPTIONAL] Rate limit (requests per minute)
# Default: 60
PRSM_RATE_LIMIT_RPM=60

# [OPTIONAL] Mock backend delay for testing
# Default: 0.1
PRSM_MOCK_DELAY=0.1

# --- Embedding Configuration ---
# [OPTIONAL] Embedding model name
# Default: text-embedding-3-small
PRSM_EMBEDDING_MODEL=text-embedding-3-small

# [OPTIONAL] Embedding dimensions
# Default: 1536
PRSM_EMBEDDING_DIMENSIONS=1536

# ========================================
# 3. BLOCKCHAIN / WEB3 (Optional)
# ========================================
# Configuration for blockchain integration and FTNS token system.

# --- Ethereum Networks ---
# [OPTIONAL] Ethereum mainnet RPC URL
MAINNET_RPC_URL=https://eth.llamarpc.com

# [OPTIONAL] Sepolia testnet RPC URL
SEPOLIA_RPC_URL=https://rpc.sepolia.org

# --- Polygon Networks ---
# [OPTIONAL] Polygon mainnet RPC URL
POLYGON_RPC_URL=https://polygon-rpc.com

# [OPTIONAL] Polygon mainnet WebSocket URL
POLYGON_MAINNET_WS_URL=wss://ws-mainnet.matic.network

# [OPTIONAL] Polygon mainnet RPC URL (alternative name)
POLYGON_MAINNET_RPC_URL=https://polygon-rpc.com

# [OPTIONAL] Polygon Mumbai testnet RPC URL
POLYGON_MUMBAI_RPC_URL=https://rpc-mumbai.maticvigil.com

# --- Web3 Configuration ---
# [OPTIONAL] Web3 network to use
# Options: polygon_mainnet, polygon_mumbai, sepolia, mainnet
WEB3_NETWORK=polygon_mumbai

# [OPTIONAL] Enable Web3 monitoring
# Default: true
WEB3_MONITORING_ENABLED=true

# [OPTIONAL] Web3 polling interval in seconds
# Default: 5
WEB3_POLL_INTERVAL=5

# --- Contract Addresses ---
# [OPTIONAL] FTNS token contract address
FTNS_TOKEN_ADDRESS=

# [OPTIONAL] FTNS marketplace contract address
FTNS_MARKETPLACE_ADDRESS=

# [OPTIONAL] FTNS governance contract address
FTNS_GOVERNANCE_ADDRESS=

# [OPTIONAL] FTNS timelock contract address
FTNS_TIMELOCK_ADDRESS=

# --- Deployer Configuration ---
# [OPTIONAL] Private key for contract deployment (NEVER commit real keys!)
DEPLOYER_PRIVATE_KEY=

# [OPTIONAL] Network-specific deployer private key
# Example: POLYGON_MUMBAI_DEPLOYER_PRIVATE_KEY
# {NETWORK}_DEPLOYER_PRIVATE_KEY=

# [OPTIONAL] Verify contracts after deployment
# Default: true
VERIFY_CONTRACTS=true

# --- Wallet Configuration ---
# [OPTIONAL] Wallet private key for transactions (NEVER commit real keys!)
WALLET_PRIVATE_KEY=

# --- Faucet Integration ---
# [OPTIONAL] Enable faucet integration
# Default: true
FAUCET_INTEGRATION_ENABLED=true

# [OPTIONAL] Auto-request from faucet
# Default: false
FAUCET_AUTO_REQUEST=false

# --- IOTA Configuration ---
# [OPTIONAL] IOTA node URL
IOTA_NODE_URL=

# [OPTIONAL] IOTA network (testnet, mainnet)
IOTA_NETWORK=testnet

# ========================================
# 4. NETWORKING (Optional)
# ========================================
# P2P and API networking configuration.

# --- API Configuration ---
# [OPTIONAL] API host address
# Default: 127.0.0.1 (localhost for security)
PRSM_API_HOST=127.0.0.1

# [OPTIONAL] API port
# Default: 8000
PRSM_API_PORT=8000

# [OPTIONAL] Enable API auto-reload (development only)
# Default: true
PRSM_API_RELOAD=true

# [OPTIONAL] Number of API workers
# Default: 1
PRSM_API_WORKERS=1

# --- P2P Configuration ---
# [OPTIONAL] Enable P2P networking
# Default: true
PRSM_P2P_ENABLED=true

# [OPTIONAL] P2P port
# Default: 4001
PRSM_P2P_PORT=4001

# [OPTIONAL] Comma-separated list of bootstrap peers
PRSM_P2P_BOOTSTRAP_PEERS=

# --- Bootstrap Server Configuration ---
# [OPTIONAL] Domain name for bootstrap server
PRSM_DOMAIN=

# [OPTIONAL] Bootstrap server host
PRSM_BOOTSTRAP_HOST=0.0.0.0

# [OPTIONAL] Bootstrap server port
PRSM_BOOTSTRAP_PORT=8765

# [OPTIONAL] External IP for NAT traversal
PRSM_EXTERNAL_IP=

# [OPTIONAL] Maximum number of peers
PRSM_MAX_PEERS=1000

# [OPTIONAL] Peer timeout in seconds
PRSM_PEER_TIMEOUT=300

# [OPTIONAL] Heartbeat interval in seconds
PRSM_HEARTBEAT_INTERVAL=30

# [OPTIONAL] Federation peers (comma-separated)
PRSM_FEDERATION_PEERS=

# [OPTIONAL] Region identifier for geo-distribution
PRSM_REGION=

# ========================================
# 5. DATABASE (Optional)
# ========================================
# Database configuration. SQLite is used by default (no config needed).

# [OPTIONAL] Database URL
# SQLite (default): sqlite:///./prsm.db
# PostgreSQL: postgresql://user:password@localhost:5432/prsm
# PostgreSQL (async): postgresql+asyncpg://user:password@localhost:5432/prsm
DATABASE_URL=sqlite:///./prsm.db

# [OPTIONAL] Alternative database URL variable
PRSM_DATABASE_URL=sqlite:///./prsm.db

# [OPTIONAL] PostgreSQL password (used by some modules)
POSTGRES_PASSWORD=

# [OPTIONAL] Enable database query logging
# Default: false
PRSM_DATABASE_ECHO=false

# [OPTIONAL] Database connection pool size
# Default: 5
PRSM_DATABASE_POOL_SIZE=5

# [OPTIONAL] Database connection pool max overflow
# Default: 10
PRSM_DATABASE_MAX_OVERFLOW=10

# ========================================
# 6. REDIS CACHE (Optional)
# ========================================
# Redis for caching and session management. System works without it.

# [OPTIONAL] Redis URL
# Default: redis://localhost:6379/0
REDIS_URL=redis://localhost:6379/0

# [OPTIONAL] Alternative Redis URL variable
PRSM_REDIS_URL=redis://localhost:6379/0

# [OPTIONAL] Redis password (if required)
PRSM_REDIS_PASSWORD=

# ========================================
# 7. IPFS STORAGE (Optional)
# ========================================
# IPFS for decentralized storage. System works without it.

# [OPTIONAL] IPFS host
# Default: localhost
IPFS_HOST=localhost

# [OPTIONAL] Alternative IPFS host variable
PRSM_IPFS_HOST=localhost

# [OPTIONAL] IPFS API port
# Default: 5001
IPFS_PORT=5001

# [OPTIONAL] Alternative IPFS port variable
PRSM_IPFS_PORT=5001

# [OPTIONAL] IPFS timeout in seconds
# Default: 60
PRSM_IPFS_TIMEOUT=60

# [OPTIONAL] IPFS gateway URL
# Default: http://localhost:8080
PRSM_IPFS_GATEWAY=http://localhost:8080

# [OPTIONAL] IPFS API address (multiaddr format)
# Default: /ip4/127.0.0.1/tcp/5001
IPFS_API_ADDR=/ip4/127.0.0.1/tcp/5001

# ========================================
# 8. VECTOR DATABASES (Optional)
# ========================================
# Vector database configuration for semantic search.

# ============================================================
# Vector Store Backend Configuration
# ============================================================
# Default backend: pgvector (PostgreSQL). Set VECTOR_STORE_TYPE to switch.
# Options: pgvector, milvus, qdrant, pinecone
VECTOR_STORE_TYPE=pgvector

# Milvus (self-hosted or Zilliz cloud)
# Self-hosted: docker run -d -p 19530:19530 milvusdb/milvus:latest
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_TOKEN=            # Leave empty for unauthenticated self-hosted

# Qdrant (self-hosted or cloud)
# Self-hosted: docker run -p 6333:6333 qdrant/qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_URL=              # Set to cloud URL (overrides HOST/PORT): https://xxx.qdrant.io
QDRANT_API_KEY=          # Required for Qdrant Cloud

# Pinecone (cloud only — requires API key)
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=us-east-1-aws    # Cloud region (used when creating new indexes)
PINECONE_INDEX_NAME=prsm-models

# --- Weaviate ---
# [OPTIONAL] Weaviate URL
WEAVIATE_URL=

# [OPTIONAL] Weaviate API key
WEAVIATE_API_KEY=

# ========================================
# 9. SECURITY SETTINGS (Optional)
# ========================================
# Advanced security configuration.

# --- Authentication ---
# [OPTIONAL] JWT secret (alternative to PRSM_SECRET_KEY)
PRSM_JWT_SECRET=

# [OPTIONAL] JWT access token expiration in minutes
# Default: 30
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# [OPTIONAL] Authentication secret for peer connections
PRSM_AUTH_SECRET=

# --- Session Security ---
# [OPTIONAL] Enable secure cookies
# Default: true
COOKIE_SECURE=true

# [OPTIONAL] Enable HTTP-only cookies
# Default: true
COOKIE_HTTPONLY=true

# [OPTIONAL] Cookie SameSite attribute
# Default: lax (options: strict, lax, none)
COOKIE_SAMESITE=lax

# [OPTIONAL] Session timeout in minutes
# Default: 30
SESSION_TIMEOUT_MINUTES=30

# --- TLS/SSL Configuration ---
# [OPTIONAL] Enable TLS
# Default: false
PRSM_TLS_ENABLED=false

# [OPTIONAL] TLS mode
# Default: verify-full
PRSM_TLS_MODE=verify-full

# [OPTIONAL] Minimum TLS version
# Default: TLSv1.2
PRSM_TLS_MIN_VERSION=TLSv1.2

# [OPTIONAL] Path to TLS certificate file
PRSM_TLS_CERT_FILE=

# [OPTIONAL] Path to TLS key file
PRSM_TLS_KEY_FILE=

# [OPTIONAL] Path to TLS CA file
PRSM_TLS_CA_FILE=

# [OPTIONAL] Verify TLS certificates
# Default: true
PRSM_TLS_VERIFY=true

# [OPTIONAL] Check TLS hostname
# Default: true
PRSM_TLS_CHECK_HOSTNAME=true

# [OPTIONAL] Enable SSL (alternative to TLS)
PRSM_SSL_ENABLED=

# [OPTIONAL] SSL certificate path
PRSM_SSL_CERT_PATH=/etc/ssl/certs/prsm.crt

# [OPTIONAL] SSL key path
PRSM_SSL_KEY_PATH=/etc/ssl/private/prsm.key

# --- HSTS (HTTP Strict Transport Security) ---
# [OPTIONAL] Enable HSTS
# Default: true
PRSM_HSTS_ENABLED=true

# [OPTIONAL] HSTS max age in seconds
# Default: 31536000 (1 year)
PRSM_HSTS_MAX_AGE=31536000

# [OPTIONAL] Include subdomains in HSTS
# Default: true
PRSM_HSTS_SUBDOMAINS=true

# [OPTIONAL] Enable HSTS preload
# Default: false
PRSM_HSTS_PRELOAD=false

# [OPTIONAL] HSTS header value
HSTS_HEADER=

# --- HTTPS Enforcement ---
# [OPTIONAL] Enforce HTTPS
# Default: true
ENFORCE_HTTPS=true

# [OPTIONAL] TLS version (alternative)
TLS_VERSION=1.2

# [OPTIONAL] TLS enabled (alternative)
TLS_ENABLED=true

# --- CORS Configuration ---
# Allowed CORS origins (comma-separated).
# Development: leave empty to use localhost defaults, or set specific values.
# Production: REQUIRED. Never use '*'. Example below:
# CORS_ORIGINS=https://prsm.ai,https://app.prsm.ai
CORS_ORIGINS=

# --- Content Security ---
# [OPTIONAL] Content Security Policy header
CONTENT_SECURITY_POLICY=

# [OPTIONAL] X-Content-Type-Options header
# Default: nosniff
X_CONTENT_TYPE_OPTIONS=nosniff

# [OPTIONAL] X-Frame-Options header
# Default: DENY
X_FRAME_OPTIONS=DENY

# [OPTIONAL] X-XSS-Protection header
# Default: 1; mode=block
X_XSS_PROTECTION=1; mode=block

# --- Encryption ---
# [OPTIONAL] Enable database encryption
# Default: true
DATABASE_ENCRYPTION=true

# [OPTIONAL] Enable storage encryption
# Default: true
STORAGE_ENCRYPTION=true

# [OPTIONAL] Enable backup encryption
# Default: true
BACKUP_ENCRYPTION=true

# [OPTIONAL] Master key for encryption (base64 encoded)
PRSM_MASTER_KEY=

# [OPTIONAL] Cache signing key
PRSM_CACHE_SIGNING_KEY=

# --- Post-Quantum Cryptography ---
# [OPTIONAL] PQC mode: disabled, hybrid, pq-only
# Default: disabled
PRSM_PQC_MODE=disabled

# --- Data Retention ---
# [OPTIONAL] Data retention period in days
# Default: 90
DATA_RETENTION_DAYS=90

# --- Security Alerting ---
# [OPTIONAL] Enable security alerting
# Default: false
SECURITY_ALERTING_ENABLED=false

# ========================================
# 10. MONITORING & LOGGING (Optional)
# ========================================
# Observability and monitoring configuration.

# --- Metrics ---
# [OPTIONAL] Enable Prometheus metrics
# Default: true
PRSM_METRICS_ENABLED=true

# [OPTIONAL] Metrics port
# Default: 9090
PRSM_METRICS_PORT=9090

# --- Real-Time Analytics Processor ---
# Controls the stream event pipeline that feeds live dashboards and aggregations
# [OPTIONAL] Enable real-time analytics
# Default: true
PRSM_ANALYTICS_ENABLED=true

# [OPTIONAL] Circular buffer capacity (number of events)
# Default: 100000
PRSM_ANALYTICS_BUFFER_SIZE=100000

# [OPTIONAL] Enable Prometheus (alternative)
PROMETHEUS_ENABLED=true

# --- Grafana ---
# [OPTIONAL] Grafana admin password
GRAFANA_PASSWORD=

# --- Logging ---
# [OPTIONAL] Security log directory
# Default: logs/security
PRSM_SECURITY_LOG_DIR=logs/security

# [OPTIONAL] Maximum log size in MB
# Default: 100
PRSM_MAX_LOG_SIZE_MB=100

# [OPTIONAL] Log retention in days
# Default: 90
PRSM_LOG_RETENTION_DAYS=90

# [OPTIONAL] Enable real-time alerts
# Default: true
PRSM_ENABLE_ALERTS=true

# [OPTIONAL] Enable log compression
# Default: true
PRSM_ENABLE_LOG_COMPRESSION=true

# [OPTIONAL] Security log level
# Default: INFO
PRSM_SECURITY_LOG_LEVEL=INFO

# [OPTIONAL] Alert webhook URL
PRSM_ALERT_WEBHOOK_URL=

# [OPTIONAL] Enable security metrics
# Default: true
PRSM_ENABLE_SECURITY_METRICS=true

# [OPTIONAL] Enable JSON logging
# Default: true
PRSM_JSON_LOGS=true

# [OPTIONAL] Environment for logging
PRSM_ENVIRONMENT=development

# [OPTIONAL] Auto-initialize logging
# Default: true
PRSM_AUTO_INIT_LOGGING=true

# ========================================
# 11. NWTN CONFIGURATION (Optional)
# ========================================
# NWTN orchestrator settings for AI model coordination.

# [OPTIONAL] Enable NWTN
# Default: true
PRSM_NWTN_ENABLED=true

# [OPTIONAL] Maximum context per query
# Default: 1000
PRSM_NWTN_MAX_CONTEXT=1000

# [OPTIONAL] Minimum context cost
# Default: 10
PRSM_NWTN_MIN_CONTEXT_COST=10

# [OPTIONAL] Default NWTN model
# Default: claude-3-5-sonnet-20241022
PRSM_NWTN_MODEL=claude-3-5-sonnet-20241022

# [OPTIONAL] NWTN temperature
# Default: 0.7
PRSM_NWTN_TEMPERATURE=0.7

# ========================================
# 12. FTNS TOKEN ECONOMY (Optional)
# ========================================
# FTNS token system configuration.

# [OPTIONAL] Enable FTNS token system
# Default: true
PRSM_FTNS_ENABLED=true

# [OPTIONAL] Initial FTNS grant for new users
# Default: 100
PRSM_FTNS_INITIAL_GRANT=100

# [OPTIONAL] Base context cost in FTNS
# Default: 0.1
PRSM_FTNS_CONTEXT_COST=0.1

# [OPTIONAL] FTNS reward multiplier
# Default: 1.0
PRSM_FTNS_REWARD_MULTIPLIER=1.0

# [OPTIONAL] Maximum session budget in FTNS
# Default: 10000
PRSM_FTNS_MAX_SESSION_BUDGET=10000

# ========================================
# 13. PAYMENT GATEWAY (Optional)
# ========================================
# Fiat and crypto payment processing configuration.

# --- Default Provider ---
# [OPTIONAL] Default payment provider: mock (dev), stripe (prod), paypal (prod)
# Default: mock
PAYMENT_DEFAULT_PROVIDER=mock

# --- Transaction Limits ---
# [OPTIONAL] Maximum single transaction amount in USD
# Default: 5000
PAYMENT_MAX_TRANSACTION_AMOUNT=5000

# [OPTIONAL] Maximum daily transaction amount per user in USD
# Default: 10000
PAYMENT_MAX_DAILY_AMOUNT=10000

# --- Stripe Integration ---
# [OPTIONAL] Stripe API key (leave empty to disable Stripe provider)
# Get your key at: https://dashboard.stripe.com/apikeys
STRIPE_API_KEY=

# [OPTIONAL] Stripe webhook secret for payment event verification
STRIPE_WEBHOOK_SECRET=

# --- PayPal Integration ---
# [OPTIONAL] PayPal client ID (leave empty to disable PayPal provider)
# Get your credentials at: https://developer.paypal.com/dashboard/
PAYPAL_CLIENT_ID=

# [OPTIONAL] PayPal client secret
PAYPAL_CLIENT_SECRET=

# [OPTIONAL] PayPal environment: sandbox or live
# Default: sandbox
PAYPAL_ENVIRONMENT=sandbox

# [OPTIONAL] PayPal webhook ID for event verification
PAYPAL_WEBHOOK_ID=

# --- CoinGecko Price Feed ---
# [OPTIONAL] CoinGecko API key for cryptocurrency price data
# Free tier works without key, add key for higher rate limits
# Get your key at: https://www.coingecko.com/en/api/pricing
COINGECKO_API_KEY=

# --- 1inch DEX Aggregator ---
# [OPTIONAL] 1inch API key for DEX aggregation (leave empty to disable)
# Get your key at: https://docs.1inch.io/docs/
ONEINCH_API_KEY=

# --- FTNS Token Pricing ---
# [OPTIONAL] FTNS internal price in USD (used when CoinGecko doesn't list FTNS)
# This is the authoritative USD price per FTNS token during testnet phase
# Default: 0.10
FTNS_USD_RATE=0.10

# [OPTIONAL] FTNS token contract address for 1inch DEX integration
# Note: Also set FTNS_TOKEN_ADDRESS in Blockchain section for full integration
FTNS_TOKEN_ADDRESS=

# ========================================
# 14. PRICE ORACLE CONFIGURATION (Optional)
# ========================================
# Price oracle configuration for FTNS token price discovery.

# CoinMarketCap API key (leave empty to disable — only needed once FTNS is listed)
CMC_API_KEY=

# FTNS CoinGecko slug (update once FTNS is listed on CoinGecko)
# Current value is a placeholder — listing pending
FTNS_COINGECKO_ID=ftns-token

# FTNS CoinMarketCap slug (update once FTNS is listed on CMC)
FTNS_CMC_SLUG=ftns-token

# FTNS CoinCap slug (update once FTNS is listed on CoinCap)
FTNS_COINCAP_ID=ftns-token

# 1inch chain for DEX quotes (137=Polygon, 1=Ethereum)
ONEINCH_CHAIN_ID=137

# ========================================
# 15. AGENT CONFIGURATION (Optional)
# ========================================
# AI agent pipeline settings.

# [OPTIONAL] Maximum task decomposition depth
# Default: 5
PRSM_MAX_DECOMPOSITION_DEPTH=5

# [OPTIONAL] Maximum parallel tasks
# Default: 10
PRSM_MAX_PARALLEL_TASKS=10

# [OPTIONAL] Agent timeout in seconds
# Default: 300
PRSM_AGENT_TIMEOUT=300

# --- Teacher Model ---
# [OPTIONAL] Enable teacher model
# Default: true
PRSM_TEACHER_ENABLED=true

# [OPTIONAL] Enable RLVR (Reinforcement Learning from Verifiable Rewards)
# Default: true
PRSM_TEACHER_RLVR_ENABLED=true

# [OPTIONAL] Teacher update frequency in seconds
# Default: 3600
PRSM_TEACHER_UPDATE_FREQ=3600

# --- Safety ---
# [OPTIONAL] Enable circuit breaker
# Default: true
PRSM_CIRCUIT_BREAKER_ENABLED=true

# [OPTIONAL] Enable safety monitoring
# Default: true
PRSM_SAFETY_MONITORING=true

# [OPTIONAL] Maximum safety violations before shutdown
# Default: 3
PRSM_MAX_SAFETY_VIOLATIONS=3

# ========================================
# 16. GOVERNANCE (Optional)
# ========================================
# Decentralized governance configuration.

# [OPTIONAL] Enable governance system
# Default: true
PRSM_GOVERNANCE_ENABLED=true

# [OPTIONAL] Proposal threshold (FTNS needed to create proposal)
# Default: 100
PRSM_GOVERNANCE_THRESHOLD=100

# [OPTIONAL] Voting period in seconds
# Default: 604800 (7 days)
PRSM_GOVERNANCE_VOTING_PERIOD=604800

# --- Recursive Self-Improvement ---
# [OPTIONAL] Enable recursive self-improvement
# Default: true
PRSM_RSI_ENABLED=true

# [OPTIONAL] RSI evaluation frequency in seconds
# Default: 86400 (24 hours)
PRSM_RSI_EVAL_FREQUENCY=86400

# [OPTIONAL] RSI improvement threshold
# Default: 0.05 (5%)
PRSM_RSI_IMPROVEMENT_THRESHOLD=0.05

# ========================================
# 17. SECRETS MANAGEMENT (Optional)
# ========================================
# External secrets management integration.

# --- Backend Selection ---
# [OPTIONAL] Secrets backend: env, vault, aws, gcp
# Default: env (environment variables)
SECRETS_BACKEND=env

# --- HashiCorp Vault ---
# [OPTIONAL] Vault server URL
VAULT_ADDR=http://localhost:8200

# [OPTIONAL] Vault token
VAULT_TOKEN=

# --- AWS Secrets Manager ---
# [OPTIONAL] AWS region
AWS_REGION=us-east-1

# --- GCP Secret Manager ---
# [OPTIONAL] GCP project ID
GCP_PROJECT=

# ========================================
# DEVELOPMENT NOTES
# ========================================
# 1. Copy this file to .env: cp .env.example .env
# 2. Fill in your values (never commit real secrets!)
# 3. For production, ensure all REQUIRED variables are set
# 4. Use strong, unique passwords and API keys
# 5. Generate secure secrets with: openssl rand -hex 32
# 6. Consider using a secrets manager for production deployments
