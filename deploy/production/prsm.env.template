# PRSM Production Node Configuration
# Copy to /opt/prsm/.env and fill in values

# Node Identity
PRSM_DISPLAY_NAME=prismatica-node-01
PRSM_DATA_DIR=/opt/prsm/data

# Network
PRSM_P2P_PORT=9001
PRSM_API_PORT=8000
PRSM_BOOTSTRAP_NODES=wss://bootstrap1.prsm-network.com:8765

# LLM Backend (required for Agent Forge)
OPENROUTER_API_KEY=your-openrouter-key-here

# Node Security
PRSM_NODE_API_KEY=generate-a-strong-key-here

# FTNS (on-chain settlement)
FTNS_WALLET_PRIVATE_KEY=your-wallet-private-key
BASE_RPC_URL=https://mainnet.base.org

# Prosumer Staking
PRSM_STAKE_AMOUNT=10000
PRSM_STAKE_TIER=sentinel

# Compute Resources
PRSM_MAX_CONCURRENT_JOBS=10
PRSM_CPU_ALLOCATION_PCT=80
PRSM_MEMORY_ALLOCATION_PCT=80
PRSM_GPU_ALLOCATION_PCT=90
PRSM_STORAGE_GB=500

# Welcome Grant for new users connecting
PRSM_WELCOME_GRANT=100
