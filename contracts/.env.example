# RPC endpoints. Base mainnet + Base Sepolia are the primary targets for
# PRSM Phase 1.3 mainnet deploy. Alchemy and Infura both work; pick one.
#
# Alchemy URL format:
#   https://base-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
#   https://base-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
#
# Infura URL format:
#   https://base-mainnet.infura.io/v3/YOUR_INFURA_KEY
#   https://base-sepolia.infura.io/v3/YOUR_INFURA_KEY
BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
BASE_SEPOLIA_RPC_URL=https://base-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Legacy / multi-chain options (not required for Phase 1.3 Base deploy)
INFURA_KEY=your_infura_key
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/${INFURA_KEY}
POLYGON_MUMBAI_RPC_URL=https://polygon-mumbai.infura.io/v3/${INFURA_KEY}
POLYGON_MAINNET_RPC_URL=https://polygon-mainnet.infura.io/v3/${INFURA_KEY}
MAINNET_RPC_URL=https://mainnet.infura.io/v3/${INFURA_KEY}

# Wallet Configuration (Use a dedicated deployment wallet - NEVER use mainnet keys for testnet!)
PRIVATE_KEY=your_private_key_here

# API Keys for Contract Verification
# ETHERSCAN_API_KEY is the V2 unified multichain key and covers Base + Base
# Sepolia via hardhat-verify customChains (see hardhat.config.js).
ETHERSCAN_API_KEY=your_etherscan_api_key
POLYGONSCAN_API_KEY=your_polygonscan_api_key
COINMARKETCAP_API_KEY=your_coinmarketcap_api_key

# Contract Addresses (filled after deployment)
FTNS_TOKEN_ADDRESS=
FTNS_MARKETPLACE_ADDRESS=
FTNS_GOVERNANCE_ADDRESS=
FTNS_PRIVACY_POOL_ADDRESS=

# Gas Configuration
REPORT_GAS=true
GAS_LIMIT_MULTIPLIER=1.2
GAS_PRICE_MULTIPLIER=1.1

# Deployment Configuration
INITIAL_SUPPLY=100000000
MAX_SUPPLY=1000000000
TREASURY_ADDRESS=