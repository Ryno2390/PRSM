{
  "dashboard": {
    "title": "PRSM Bootstrap Server",
    "uid": "prsm-bootstrap",
    "tags": ["prsm", "bootstrap", "p2p"],
    "timezone": "browser",
    "schemaVersion": 16,
    "version": 1,
    "refresh": "30s",
    "time": {
      "from": "now-1h",
      "to": "now"
    },
    "panels": [
      {
        "id": 1,
        "title": "Server Status",
        "type": "stat",
        "gridPos": {
          "h": 4,
          "w": 4,
          "x": 0,
          "y": 0
        },
        "targets": [
          {
            "expr": "up{job=\"prsm-bootstrap\"}",
            "refId": "A",
            "legendFormat": "{{ instance }}"
          }
        ],
        "options": {
          "colorMode": "background",
          "graphMode": "none",
          "reduceOptions": {
            "calcs": ["lastNotNull"],
            "fields": "",
            "values": false
          }
        },
        "fieldConfig": {
          "defaults": {
            "mappings": [
              {
                "type": "value",
                "options": {
                  "1": {
                    "text": "UP",
                    "color": "green"
                  },
                  "0": {
                    "text": "DOWN",
                    "color": "red"
                  }
                }
              }
            ],
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": null, "color": "red"},
                {"value": 1, "color": "green"}
              ]
            }
          }
        }
      },
      {
        "id": 2,
        "title": "Active Connections",
        "type": "stat",
        "gridPos": {
          "h": 4,
          "w": 4,
          "x": 4,
          "y": 0
        },
        "targets": [
          {
            "expr": "prsm_bootstrap_active_connections",
            "refId": "A"
          }
        ],
        "options": {
          "colorMode": "value",
          "graphMode": "area",
          "reduceOptions": {
            "calcs": ["lastNotNull"],
            "fields": "",
            "values": false
          }
        },
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": null, "color": "green"},
                {"value": 500, "color": "yellow"},
                {"value": 800, "color": "red"}
              ]
            }
          }
        }
      },
      {
        "id": 3,
        "title": "Total Peers",
        "type": "stat",
        "gridPos": {
          "h": 4,
          "w": 4,
          "x": 8,
          "y": 0
        },
        "targets": [
          {
            "expr": "prsm_bootstrap_total_peers",
            "refId": "A"
          }
        ],
        "options": {
          "colorMode": "value",
          "graphMode": "area",
          "reduceOptions": {
            "calcs": ["lastNotNull"],
            "fields": "",
            "values": false
          }
        },
        "fieldConfig": {
          "defaults": {
            "unit": "short"
          }
        }
      },
      {
        "id": 4,
        "title": "Uptime",
        "type": "stat",
        "gridPos": {
          "h": 4,
          "w": 4,
          "x": 12,
          "y": 0
        },
        "targets": [
          {
            "expr": "prsm_bootstrap_uptime_seconds",
            "refId": "A"
          }
        ],
        "options": {
          "colorMode": "value",
          "graphMode": "none",
          "reduceOptions": {
            "calcs": ["lastNotNull"],
            "fields": "",
            "values": false
          }
        },
        "fieldConfig": {
          "defaults": {
            "unit": "s"
          }
        }
      },
      {
        "id": 5,
        "title": "Messages Processed",
        "type": "stat",
        "gridPos": {
          "h": 4,
          "w": 4,
          "x": 16,
          "y": 0
        },
        "targets": [
          {
            "expr": "prsm_bootstrap_messages_processed_total",
            "refId": "A"
          }
        ],
        "options": {
          "colorMode": "value",
          "graphMode": "area",
          "reduceOptions": {
            "calcs": ["lastNotNull"],
            "fields": "",
            "values": false
          }
        },
        "fieldConfig": {
          "defaults": {
            "unit": "short"
          }
        }
      },
      {
        "id": 6,
        "title": "Error Rate",
        "type": "stat",
        "gridPos": {
          "h": 4,
          "w": 4,
          "x": 20,
          "y": 0
        },
        "targets": [
          {
            "expr": "rate(prsm_bootstrap_errors_total[5m])",
            "refId": "A"
          }
        ],
        "options": {
          "colorMode": "value",
          "graphMode": "area",
          "reduceOptions": {
            "calcs": ["lastNotNull"],
            "fields": "",
            "values": false
          }
        },
        "fieldConfig": {
          "defaults": {
            "unit": "ops",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": null, "color": "green"},
                {"value": 1, "color": "yellow"},
                {"value": 10, "color": "red"}
              ]
            }
          }
        }
      },
      {
        "id": 7,
        "title": "Connections Over Time",
        "type": "timeseries",
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 4
        },
        "targets": [
          {
            "expr": "prsm_bootstrap_active_connections",
            "refId": "A",
            "legendFormat": "Active Connections"
          },
          {
            "expr": "prsm_bootstrap_total_peers",
            "refId": "B",
            "legendFormat": "Total Peers"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "custom": {
              "lineWidth": 2,
              "fillOpacity": 10
            }
          }
        }
      },
      {
        "id": 8,
        "title": "Network Traffic",
        "type": "timeseries",
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 4
        },
        "targets": [
          {
            "expr": "rate(prsm_bootstrap_bytes_sent_total[5m])",
            "refId": "A",
            "legendFormat": "Bytes Sent/sec"
          },
          {
            "expr": "rate(prsm_bootstrap_bytes_received_total[5m])",
            "refId": "B",
            "legendFormat": "Bytes Received/sec"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "Bps",
            "custom": {
              "lineWidth": 2,
              "fillOpacity": 10
            }
          }
        }
      },
      {
        "id": 9,
        "title": "Request Latency",
        "type": "timeseries",
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 12
        },
        "targets": [
          {
            "expr": "histogram_quantile(0.50, rate(prsm_bootstrap_request_duration_seconds_bucket[5m]))",
            "refId": "A",
            "legendFormat": "p50"
          },
          {
            "expr": "histogram_quantile(0.95, rate(prsm_bootstrap_request_duration_seconds_bucket[5m]))",
            "refId": "B",
            "legendFormat": "p95"
          },
          {
            "expr": "histogram_quantile(0.99, rate(prsm_bootstrap_request_duration_seconds_bucket[5m]))",
            "refId": "C",
            "legendFormat": "p99"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "s",
            "custom": {
              "lineWidth": 2
            }
          }
        }
      },
      {
        "id": 10,
        "title": "Connection Events",
        "type": "timeseries",
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 12
        },
        "targets": [
          {
            "expr": "rate(prsm_bootstrap_total_connections_total[5m])",
            "refId": "A",
            "legendFormat": "New Connections/sec"
          },
          {
            "expr": "rate(prsm_bootstrap_failed_connections_total[5m])",
            "refId": "B",
            "legendFormat": "Failed Connections/sec"
          },
          {
            "expr": "rate(prsm_bootstrap_rejected_connections_total[5m])",
            "refId": "C",
            "legendFormat": "Rejected Connections/sec"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "ops",
            "custom": {
              "lineWidth": 2
            }
          }
        }
      },
      {
        "id": 11,
        "title": "Peers by Region",
        "type": "piechart",
        "gridPos": {
          "h": 8,
          "w": 8,
          "x": 0,
          "y": 20
        },
        "targets": [
          {
            "expr": "sum by (region) (prsm_bootstrap_peers_by_region)",
            "refId": "A",
            "legendFormat": "{{ region }}"
          }
        ],
        "options": {
          "legend": {
            "displayMode": "table",
            "placement": "right"
          }
        }
      },
      {
        "id": 12,
        "title": "Peers by Capability",
        "type": "piechart",
        "gridPos": {
          "h": 8,
          "w": 8,
          "x": 8,
          "y": 20
        },
        "targets": [
          {
            "expr": "sum by (capability) (prsm_bootstrap_peers_by_capability)",
            "refId": "A",
            "legendFormat": "{{ capability }}"
          }
        ],
        "options": {
          "legend": {
            "displayMode": "table",
            "placement": "right"
          }
        }
      },
      {
        "id": 13,
        "title": "System Resources",
        "type": "timeseries",
        "gridPos": {
          "h": 8,
          "w": 8,
          "x": 16,
          "y": 20
        },
        "targets": [
          {
            "expr": "100 - (avg by(instance) (irate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
            "refId": "A",
            "legendFormat": "CPU %"
          },
          {
            "expr": "(1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)) * 100",
            "refId": "B",
            "legendFormat": "Memory %"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "max": 100,
            "min": 0,
            "custom": {
              "lineWidth": 2
            }
          }
        }
      },
      {
        "id": 14,
        "title": "Connection Rate",
        "type": "timeseries",
        "gridPos": {
          "h": 6,
          "w": 8,
          "x": 0,
          "y": 28
        },
        "targets": [
          {
            "expr": "rate(prsm_bootstrap_total_connections_total[1m]) * 60",
            "refId": "A",
            "legendFormat": "Connections/min"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "custom": {
              "lineWidth": 2,
              "fillOpacity": 10
            }
          }
        },
        "description": "Rate of new connections per minute"
      },
      {
        "id": 15,
        "title": "Message Throughput",
        "type": "timeseries",
        "gridPos": {
          "h": 6,
          "w": 8,
          "x": 8,
          "y": 28
        },
        "targets": [
          {
            "expr": "rate(prsm_bootstrap_messages_processed_total[1m])",
            "refId": "A",
            "legendFormat": "Messages/sec"
          },
          {
            "expr": "rate(prsm_bootstrap_messages_sent_total[1m])",
            "refId": "B",
            "legendFormat": "Sent/sec"
          },
          {
            "expr": "rate(prsm_bootstrap_messages_received_total[1m])",
            "refId": "C",
            "legendFormat": "Received/sec"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "ops",
            "custom": {
              "lineWidth": 2,
              "fillOpacity": 10
            }
          }
        },
        "description": "Message throughput in messages per second"
      },
      {
        "id": 16,
        "title": "Peer Churn Rate",
        "type": "timeseries",
        "gridPos": {
          "h": 6,
          "w": 8,
          "x": 16,
          "y": 28
        },
        "targets": [
          {
            "expr": "rate(prsm_bootstrap_peer_disconnections_total[1m]) * 60",
            "refId": "A",
            "legendFormat": "Disconnects/min"
          },
          {
            "expr": "rate(prsm_bootstrap_peer_connections_total[1m]) * 60",
            "refId": "B",
            "legendFormat": "New Peers/min"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "custom": {
              "lineWidth": 2,
              "fillOpacity": 10
            },
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": null, "color": "green"},
                {"value": 10, "color": "yellow"},
                {"value": 50, "color": "red"}
              ]
            }
          }
        },
        "description": "Peer churn rate - disconnects and new connections per minute"
      },
      {
        "id": 17,
        "title": "FTNS Transaction Volume",
        "type": "timeseries",
        "gridPos": {
          "h": 6,
          "w": 12,
          "x": 0,
          "y": 34
        },
        "targets": [
          {
            "expr": "rate(prsm_ftns_transactions_total[5m]) * 60",
            "refId": "A",
            "legendFormat": "Transactions/min"
          },
          {
            "expr": "rate(prsm_ftns_volume_total[5m])",
            "refId": "B",
            "legendFormat": "Volume/sec (FTNS)"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "custom": {
              "lineWidth": 2,
              "fillOpacity": 10
            }
          }
        },
        "description": "FTNS token transaction volume and rate"
      },
      {
        "id": 18,
        "title": "Compute Job Queue Depth",
        "type": "stat",
        "gridPos": {
          "h": 6,
          "w": 6,
          "x": 12,
          "y": 34
        },
        "targets": [
          {
            "expr": "prsm_compute_queue_depth",
            "refId": "A"
          }
        ],
        "options": {
          "colorMode": "value",
          "graphMode": "area",
          "reduceOptions": {
            "calcs": ["lastNotNull"],
            "fields": "",
            "values": false
          }
        },
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": null, "color": "green"},
                {"value": 50, "color": "yellow"},
                {"value": 100, "color": "red"}
              ]
            }
          }
        },
        "description": "Current depth of compute job queue"
      },
      {
        "id": 19,
        "title": "Error Rate (Percentage)",
        "type": "gauge",
        "gridPos": {
          "h": 6,
          "w": 6,
          "x": 18,
          "y": 34
        },
        "targets": [
          {
            "expr": "(rate(prsm_bootstrap_errors_total[5m]) / (rate(prsm_bootstrap_requests_total[5m]) + 0.001)) * 100",
            "refId": "A"
          }
        ],
        "options": {
          "showThresholdLabels": true,
          "showThresholdMarkers": true
        },
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0,
            "max": 100,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": null, "color": "green"},
                {"value": 5, "color": "yellow"},
                {"value": 10, "color": "red"}
              ]
            }
          }
        },
        "description": "Error rate as percentage of total requests"
      },
      {
        "id": 20,
        "title": "Active Peer Count",
        "type": "stat",
        "gridPos": {
          "h": 4,
          "w": 6,
          "x": 0,
          "y": 40
        },
        "targets": [
          {
            "expr": "prsm_bootstrap_active_peers",
            "refId": "A"
          }
        ],
        "options": {
          "colorMode": "background",
          "graphMode": "area",
          "reduceOptions": {
            "calcs": ["lastNotNull"],
            "fields": "",
            "values": false
          }
        },
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": null, "color": "red"},
                {"value": 1, "color": "green"}
              ]
            }
          }
        },
        "description": "Currently active peers in the network"
      },
      {
        "id": 21,
        "title": "FTNS Balance (Bootstrap Server)",
        "type": "stat",
        "gridPos": {
          "h": 4,
          "w": 6,
          "x": 6,
          "y": 40
        },
        "targets": [
          {
            "expr": "prsm_ftns_bootstrap_balance",
            "refId": "A"
          }
        ],
        "options": {
          "colorMode": "value",
          "graphMode": "area",
          "reduceOptions": {
            "calcs": ["lastNotNull"],
            "fields": "",
            "values": false
          }
        },
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": null, "color": "red"},
                {"value": 1000, "color": "yellow"},
                {"value": 10000, "color": "green"}
              ]
            }
          }
        },
        "description": "FTNS token balance for bootstrap server operations"
      }
    ]
  }
}
